def usar_la_fuerza(mochila, posicion):
    if posicion < 0:
        return "No se encontró el sable"

    if mochila[posicion] == "sable de luz":
        return f"Se encontró el sable en la posición {posicion}"
    else:
        return usar_la_fuerza(mochila, posicion - 1)

Mochila = ["sable de luz", "comida", "capa"]
print(usar_la_fuerza(Mochila, len(Mochila) - 1))


